# Port on the host machine to expose the site on.
HOST_PORT=8084

# Browser tab title and page heading for each page.
SITE_TITLE_TI84=TI-84 Calculator
SITE_TITLE_GRAPHING=Graphing Calculator Online

# Default theme for first-time visitors: "dark" or "light".
# Users can still toggle; their choice is saved in localStorage.
THEME_DEFAULT=dark

# Source URL for the embedded TI-84 iframe on the TI-84 page.
TI84_IFRAME_SRC=https://ti84calc.com/ti84calc