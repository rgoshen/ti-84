# Port on the host machine to expose the site on.
HOST_PORT=8084

# Build-time site configuration. These are baked into the static site during
# `docker compose build`, so changing one requires a rebuild:
#   docker compose up -d --build

# Browser tab title and page heading for each page.
PUBLIC_SITE_TITLE_TI84=TI-84 Calculator
PUBLIC_SITE_TITLE_GRAPHING=Graphing Calculator Online

# Source URL for the embedded TI-84 iframe on the /ti-84 page.
PUBLIC_TI84_IFRAME_SRC=https://ti84calc.com/ti84calc

# Default theme for first-time visitors: "dark" or "light".
# Visitors can still toggle; their choice is saved in localStorage.
PUBLIC_THEME_DEFAULT=dark
