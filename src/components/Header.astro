---
// Shared sticky site header: brand + nav with an active-page indicator, plus a
// light/dark theme toggle. Colors use the shadcn/Tailwind theme tokens so they
// follow the `.dark` class set by the Base layout's theme bootstrap.
const links = [
  { href: '/', label: 'Home' },
  { href: '/ti-84', label: 'TI-84' },
  { href: '/graphing', label: 'Graphing' },
] as const;

// Normalize a trailing slash so "/ti-84" and "/ti-84/" match the same nav link.
const normalize = (path: string): string =>
  path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const current = normalize(Astro.url.pathname);
const isActive = (href: string): boolean => normalize(href) === current;
---

<header class="sticky top-0 z-20 border-b bg-background/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <div class="flex items-center gap-6">
      <a href="/" class="text-xl font-semibold tracking-tight">Online Calculators</a>
      <nav aria-label="Main" class="flex items-center gap-1">
        {
          links.map((link) => (
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
                isActive(link.href)
                  ? 'bg-muted text-foreground'
                  : 'text-muted-foreground hover:bg-muted hover:text-foreground',
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle theme"
      class="inline-flex items-center gap-2 rounded-md border px-3 py-1.5 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
    >
      {/* Sun icon — shown in dark mode (click to go light). */}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="hidden h-4 w-4 dark:block"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <path
          stroke-linecap="round"
          d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"
        ></path>
      </svg>
      {/* Moon icon — shown in light mode (click to go dark). */}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="block h-4 w-4 dark:hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1111.2 3 7 7 0 0021 12.8z"></path>
      </svg>
      <span id="theme-label">Theme</span>
    </button>
  </div>
</header>

<script>
  // Wire the theme toggle: flip `.dark`, persist the choice, and keep the label
  // in sync. The Base layout already applied the correct theme before paint.
  const toggle = document.getElementById('theme-toggle');
  const label = document.getElementById('theme-label');
  const root = document.documentElement;

  const syncLabel = (): void => {
    if (label) label.textContent = root.classList.contains('dark') ? 'Dark' : 'Light';
  };

  syncLabel();

  toggle?.addEventListener('click', () => {
    const isDark = root.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    syncLabel();
  });
</script>
